# Example environment for OpenMemory when using Ollama embeddings (Docker Compose).
# Copy values into the `.env` used by your OpenMemory stack, or merge into compose `environment:`.
#
# References: OpenMemory repo (CaviraOSS/OpenMemory); align with your opencode / host setup.

# Use Ollama for embeddings inside the OpenMemory container
OM_EMBEDDINGS=ollama

# Tier / model depth (project-specific; see OpenMemory docs for valid values)
OM_TIER=deep

# Vector dimension must match the embedding model (e.g. 768 for common small models)
OM_VEC_DIM=768

# Where the OpenMemory container reaches Ollama (Docker Desktop → host)
OLLAMA_URL=http://host.docker.internal:11434

# Optional: if your OpenMemory instance requires an API key on /mcp, set in manifest headers
# and export here for Cursor / OpenCode interpolation:
# OM_API_KEY=
