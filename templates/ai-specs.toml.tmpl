# ai-specs.toml — manifiesto raíz del estándar ai-specs.
#
# ONLY V1 source of truth del proyecto. La superficie canónica de este cambio es:
#   [project]       optional section
#   [agents]        optional section (default: enabled = [])
#   [[deps]]        optional repeated section (ONLY required per entry: id, source)
#   [mcp.<name>]    optional repeated section
# Ninguna otra sección forma parte de la superficie canónica V1 en este cambio.
#
# Skills locales viven en ai-specs/skills/<name>/ y se autodescubren del
# filesystem (no se listan acá).
# V1 NO agrega precedence, doctor ni [memory]; quedan deferidos a cambios futuros.
#
# Comandos (CLI global, publicado hoy desde https://github.com/parada1104/ai-specs-cli):
#   ai-specs init                # bootstrap el directorio ai-specs/ (idempotente)
#   ai-specs sync                # vendoreá deps + regenerá AGENTS.md + fan-out root + subrepos
#   ai-specs sync-agent --all    # distribuí skills + MCP a cada agente habilitado
#   /skills-as-rules             # desde tu agente: formalizá una convención como skill local
#   ai-specs add-dep <url>       # agregá una skill vendoreada a [[deps]]

[project]
# Optional section. `name` es opcional; default: "".
name = "{{PROJECT_NAME}}"
# Optional field. Default: []. Solo acepta paths relativos válidos al root.
# V1: se usan como targets derivados de sync; NO crean manifests locales.
subrepos = []

[agents]
# Optional section. `enabled` default: []. Solo estos reciben configs.
# Opciones soportadas hoy: claude, cursor, opencode, codex, copilot, gemini.
enabled = ["claude", "cursor", "opencode"]

# -----------------------------------------------------------------------------
# Deps de skills externas
# -----------------------------------------------------------------------------
# Cada [[deps]] se clona a ai-specs/skills/<id>/ por `ai-specs sync`
# (lib/_internal/vendor-skills.py). El frontmatter upstream se reemplaza por
# uno estándar (name, description con atribución, license, metadata).
#
# V1 contract por entry:
#   id                  required; carpeta destino bajo skills/
#   source              required; URL git (cualquier cosa que acepte `git clone`)
#   path                optional; subdir del repo donde vive SKILL.md
#   scope               optional; default ["root"]
#   auto_invoke         optional; frases para la tabla Auto-invoke de AGENTS.md
#   license             optional; SPDX id
#   vendor_attribution  optional; autor/org upstream citado en la description
#
# Ejemplo (skill puntual de un repo multi-skill):
# [[deps]]
# id = "tdd"
# source = "https://github.com/obra/superpowers"
# path = "skills/test-driven-development"
# scope = ["root"]
# auto_invoke = ["Writing or modifying tests"]
# license = "MIT"
# vendor_attribution = "obra"

# -----------------------------------------------------------------------------
# MCP servers — distribuidos por sync-agent al formato de cada plataforma
# -----------------------------------------------------------------------------
# Variables de entorno se cargan vía .envrc; los agentes interpolan los valores
# (p. ej. $TRELLO_API_KEY en runtime).
#
# V1 por servidor [mcp.<name>]:
#   command      optional; string o list
#   args         optional; default []
#   env          optional campo canónico; default {}
#   environment  tolerated input alias de `env`; no nombre canónico
#   timeout      optional; default null
#   enabled      tolerated passthrough; no amplía el contrato V1

# [mcp.example]
# command = "npx"
# args = ["-y", "@example/mcp-server"]
# env = { API_KEY = "$EXAMPLE_API_KEY" }
# timeout = 30000
