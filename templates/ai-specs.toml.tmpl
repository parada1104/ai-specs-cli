# ai-specs.toml — manifiesto raíz del estándar ai-specs.
#
# Source of truth para: agentes habilitados, skills vendoreadas (deps),
# servidores MCP. Skills locales viven en ai-specs/skills/<name>/ y se
# autodescubren del filesystem (no se listan acá).
#
# Comandos (CLI global, instalado vía https://github.com/nnodes/specs-ai-cli):
#   specs-ai init                # bootstrap el directorio ai-specs/ (idempotente)
#   specs-ai sync                # vendoreá deps + regenerá AGENTS.md + sync-agent --all
#   specs-ai sync-agent --all    # distribuí skills + MCP a cada agente habilitado
#   specs-ai add-skill <name>    # creá una skill local (no toca este TOML)
#   specs-ai add-dep <url>       # agregá una skill vendoreada a [[deps]]

[project]
name = "{{PROJECT_NAME}}"
# Lista de subrepos relativos al root. Vacío = monorepo plano.
subrepos = []

[agents]
# Agentes habilitados para sync-agent. Solo estos reciben configs.
# Opciones: claude, cursor, opencode, codex, copilot, gemini
enabled = ["claude", "cursor", "opencode"]

# -----------------------------------------------------------------------------
# Deps de skills externas
# -----------------------------------------------------------------------------
# Cada [[deps]] se clona a ai-specs/skills/<id>/ por `specs-ai sync`
# (lib/_internal/vendor-skills.py). El frontmatter upstream se reemplaza por
# uno estándar (name, description con atribución, license, metadata).
#
# Schema:
#   id                  (req) carpeta destino bajo skills/
#   source              (req) URL git (cualquier cosa que acepte `git clone`)
#   path                (opt) subdir del repo donde vive SKILL.md (multi-skill repos)
#   scope               (opt) lista — default ["root"]
#   auto_invoke         (opt) lista de frases para la tabla Auto-invoke de AGENTS.md
#   license             (opt) SPDX id
#   vendor_attribution  (opt) autor/org upstream — citado en la description
#
# Ejemplo (skill puntual de un repo multi-skill):
# [[deps]]
# id = "tdd"
# source = "https://github.com/obra/superpowers"
# path = "skills/test-driven-development"
# scope = ["root"]
# auto_invoke = ["Writing or modifying tests"]
# license = "MIT"
# vendor_attribution = "obra"

# -----------------------------------------------------------------------------
# MCP servers — distribuidos por sync-agent al formato de cada plataforma
# -----------------------------------------------------------------------------
# Variables de entorno se cargan vía .envrc; los agentes interpolan los valores
# (p. ej. $TRELLO_API_KEY en runtime).

# [mcp.example]
# command = "npx"
# args = ["-y", "@example/mcp-server"]
# env = { API_KEY = "$EXAMPLE_API_KEY" }
# timeout = 30000
