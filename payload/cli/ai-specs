#!/usr/bin/env bash
# ai-specs — Entrypoint del CLI.
#
# Subcomandos:
#   init              Bootstrap: vendor skills + regenerate AGENTS.md
#   sync-agent        Distribute skills + MCP to agents
#   add-skill         Create a local skill (autodiscovered, no TOML edit)
#   add-dep           Add a vendored skill to ai-specs.toml [[deps]]
#   sync              Shortcut: init + sync-agent --all
#
# Usage:
#   ai-specs <subcommand> [options]
#   ai-specs --help

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

show_help() {
    cat <<EOF
ai-specs — declarative AI agent config manager

Usage:
  ai-specs <subcommand> [options]

Subcommands:
  init              Read ai-specs.toml, vendor [[deps]], regenerate AGENTS.md
  sync-agent        Distribute skills + MCP to agents (Claude/Cursor/etc.)
  add-skill <name>  Create a local skill from template
  add-dep <url>     Add a vendored skill to ai-specs.toml
  sync              Shortcut: init + sync-agent --all

Run \`ai-specs <subcommand> --help\` for subcommand-specific options.

Manifest:    ai-specs/ai-specs.toml
Local skills: ai-specs/skills/<name>/SKILL.md  (autodiscovered)
EOF
}

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

SUBCMD="$1"
shift

case "$SUBCMD" in
    init)
        exec bash "$SCRIPT_DIR/init.sh" "$@"
        ;;
    sync-agent)
        exec bash "$SCRIPT_DIR/sync-agent.sh" "$@"
        ;;
    add-skill)
        exec bash "$SCRIPT_DIR/add-skill.sh" "$@"
        ;;
    add-dep)
        exec bash "$SCRIPT_DIR/add-dep.sh" "$@"
        ;;
    sync)
        bash "$SCRIPT_DIR/init.sh"
        echo ""
        exec bash "$SCRIPT_DIR/sync-agent.sh" --all "$@"
        ;;
    --help|-h|help)
        show_help
        ;;
    *)
        echo "error: unknown subcommand '$SUBCMD'"
        echo ""
        show_help
        exit 1
        ;;
esac
